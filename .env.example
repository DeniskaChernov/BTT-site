# PostgreSQL (Railway: переменная из плагина Postgres → скопируйте в DATABASE_URL)
# Пример: postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway?sslmode=require
# При деплое миграции применяются при старте: npm start → prisma migrate deploy && next start
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Локально (docker compose up -d): см. docker-compose.yml
# DATABASE_URL="postgresql://btt:btt_dev@localhost:5432/bententrade?schema=public"

# Операторский API: GET /api/admin/orders — список заказов (Bearer). Минимум 24 символа.
# curl -H "Authorization: Bearer YOUR_SECRET" "http://localhost:3000/api/admin/orders?take=20"
# curl -H "Authorization: Bearer YOUR_SECRET" "http://localhost:3000/api/admin/summary"
# ADMIN_API_SECRET=""

# URL приёма webhook в CRM (POST JSON при новом заказе). Подпись: X-BTT-Signature: sha256=<HMAC-SHA256 body>
# CRM_WEBHOOK_URL=""
# CRM_WEBHOOK_SECRET=""

# Публичный URL сайта (в webhook payload). На Vercel можно не задавать — подставится VERCEL_URL
# NEXT_PUBLIC_SITE_URL="https://bententrade.uz"

# Telegram: коллективные заказы (без @). Deep link: t.me/<username>?start=...
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_collective_bot"
# NEXT_PUBLIC_TELEGRAM_CHANNEL_USERNAME="your_channel"

# Только если Image Optimization падает с EACCES и вы не используете исправленный Dockerfile:
# NEXT_IMAGE_UNOPTIMIZED=1

# Ошибка P3005: в Docker при старте скрипт scripts/docker-entry.sh сам вызывает
# migrate resolve --applied и повторный deploy (если таблицы уже совпадают с миграцией).
# Отключить авто-baseline: PRISMA_AUTO_BASELINE=0
# Ручной resolve: npm run db:resolve-init (с прод DATABASE_URL)
# https://pris.ly/d/migrate-baseline

# Диагностика: GET /api/health — только процесс; GET /api/health?db=1 — пинг PostgreSQL (не для частого polling).

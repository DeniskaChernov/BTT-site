generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  totalUz      Int
  status       OrderStatus @default(NEW)
  statusUpdatedAt DateTime @default(now())
  statusNote   String?
  paymentStatus PaymentStatus @default(PENDING)
  paymentStatusUpdatedAt DateTime @default(now())
  paymentProvider String?
  paymentReference String?
  paymentUrl    String?
  paymentRequestedAt DateTime?
  paidAt        DateTime?
  trackingProvider String?
  trackingNumber String?
  trackingUrl  String?
  pay          String
  ship         String
  customerName String
  phone        String
  address      String?
  lines        OrderLine[]

  @@index([status])
  @@index([phone])
  @@map("orders")
}

model OrderLine {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku         String
  slug        String
  name        String
  qtyKg       Float
  lineTotalUz Int

  @@index([orderId])
  @@map("order_lines")
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  kind      String
  locale    String
  fields    Json
  quiz      Json?

  @@index([kind])
  @@index([createdAt])
  @@map("leads")
}

enum OrderStatus {
  NEW
  CONFIRMED
  PACKING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  REQUIRES_ACTION
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

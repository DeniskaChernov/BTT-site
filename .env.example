# PostgreSQL (Railway: переменная из плагина Postgres → скопируйте в DATABASE_URL)
# Пример: postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway?sslmode=require
# При деплое миграции применяются при старте: npm start → prisma migrate deploy && next start
# Таблица `leads` — заявки с форм и квиза (POST /api/leads); без DATABASE_URL лиды только в CRM webhook.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Локально (docker compose up -d): см. docker-compose.yml
# DATABASE_URL="postgresql://btt:btt_dev@localhost:5432/bententrade?schema=public"

# Операторский API: GET /api/admin/orders — список заказов (Bearer). Минимум 24 символа.
# curl -H "Authorization: Bearer YOUR_SECRET" "http://localhost:3000/api/admin/orders?take=20"
# curl -H "Authorization: Bearer YOUR_SECRET" "http://localhost:3000/api/admin/summary"
# ADMIN_API_SECRET=""
# ORDER_HISTORY_TOKEN_SECRET=""  # секрет для подписания токена просмотра истории заказов; fallback: ADMIN_API_SECRET

# Внешний rate limit (Upstash Redis REST). Если не задано — используется in-memory fallback.
# UPSTASH_REDIS_REST_URL="https://<instance>.upstash.io"
# UPSTASH_REDIS_REST_TOKEN=""

# --- Исходящая интеграция с CRM (контракт в коде: `src/lib/crm/`) ---
# POST JSON на URL; тело подписывается HMAC-SHA256 (секрет ≥16 символов).
# События: order.created, order.updated, lead.submitted; в теле есть schemaVersion, payloadId, source: "btt-site".
# Заголовки: X-BTT-Event, X-BTT-Signature: sha256=<hex>, X-BTT-Schema-Version, X-BTT-Idempotency-Key, опционально X-Request-Id.
# CRM_WEBHOOK_URL=""
# CRM_WEBHOOK_SECRET=""
# Таймаут HTTP к приёмнику, мс (3000–60000, по умолчанию 12000)
# CRM_WEBHOOK_TIMEOUT_MS="12000"

# Публичный URL сайта (в webhook payload). На Vercel можно не задавать — подставится VERCEL_URL
# NEXT_PUBLIC_SITE_URL="https://bententrade.uz"

# Google Tag Manager — подключает контейнер; события квиза и `trackEvent` уходят в тот же dataLayer
# NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"

# --- Уведомления клиентам (SMS/WhatsApp/Telegram и т.п. через ваш backend) ---
# POST JSON; тело подписывается HMAC-SHA256 (секрет ≥16 символов). Заголовки: X-BTT-Notify-Signature: sha256=<hex>, X-BTT-Notify-Reason.
# Если не заданы — сайт просто не шлёт эти webhook-и (заказ в БД и CRM не затрагиваются).
# CUSTOMER_NOTIFY_WEBHOOK_URL=""
# CUSTOMER_NOTIFY_WEBHOOK_SECRET=""

# --- Входящий webhook от платёжного шлюза (нормализация статуса в БД) ---
# POST на /api/payments/webhook/<provider>, где <provider> — см. PAYMENT_PROVIDER в src/lib/payments/contract.ts (например payme, click).
# Заголовок подписи: X-BTT-Pay-Signature: sha256=<hex> — HMAC-SHA256 от сырого тела UTF-8 с ключом PAYMENT_WEBHOOK_SHARED_SECRET (≥16 символов).
# Тело JSON: status (pending|requires_action|succeeded|failed|refunded|partially_refunded), orderId или пара paymentReference + provider для поиска; опционально paymentUrl, paidAt (ISO).
# PAYMENT_WEBHOOK_SHARED_SECRET=""

# Telegram: коллективные заказы (без @). Deep link: t.me/<username>?start=...
# Публичный канал витрины (как на bententrade.uz): @BenTenTrade
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_collective_bot"
# NEXT_PUBLIC_TELEGRAM_CHANNEL_USERNAME="BenTenTrade"

# Личный чат для согласования оплаты после оформления заказа (username без @).
# Если не задан — используется бот, затем канал. Кнопка «Открыть Telegram» на странице успеха.
# NEXT_PUBLIC_TELEGRAM_PAYMENT_USERNAME="YourUsername"

# Только если Image Optimization падает с EACCES и вы не используете исправленный Dockerfile:
# NEXT_IMAGE_UNOPTIMIZED=1

# Ошибка P3005: в Docker при старте скрипт scripts/docker-entry.sh сам вызывает
# migrate resolve --applied и повторный deploy (если таблицы уже совпадают с миграцией).
# Отключить авто-baseline: PRISMA_AUTO_BASELINE=0
# Ручной resolve: npm run db:resolve-init (с прод DATABASE_URL)
# https://pris.ly/d/migrate-baseline

# Диагностика: GET /api/health — только процесс; GET /api/health?db=1 — пинг PostgreSQL (не для частого polling).

# PostgreSQL (Railway: переменная из плагина Postgres → скопируйте в DATABASE_URL)
# Пример: postgresql://postgres:PASSWORD@HOST.railway.app:PORT/railway?sslmode=require
# При деплое миграции применяются при старте: npm start → prisma migrate deploy && next start
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Только если Image Optimization падает с EACCES и вы не используете исправленный Dockerfile:
# NEXT_IMAGE_UNOPTIMIZED=1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id           String      @id @default(cuid())
  createdAt    DateTime    @default(now())
  totalUz      Int
  pay          String
  ship         String
  customerName String
  phone        String
  address      String?
  lines        OrderLine[]

  @@index([phone])
  @@map("orders")
}

model OrderLine {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sku         String
  slug        String
  name        String
  qtyKg       Float
  lineTotalUz Int

  @@index([orderId])
  @@map("order_lines")
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  kind      String
  locale    String
  fields    Json
  quiz      Json?

  @@index([kind])
  @@index([createdAt])
  @@map("leads")
}
